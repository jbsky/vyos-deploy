$TTL    604800
@  IN  SOA  ns.home.arpa. admin.home.arpa. (
     2026010100        ; Serial
       604800         ; Refresh
        86400         ; Retry
      2592000         ; Expire
       604800 )       ; Negative Cache TTL
@                      IN  NS   ns.home.arpa.
; Exemple -- remplace par les hostnames/IPs de ton propre reseau.
ns                     IN   A   203.0.113.10
router                 IN   A   192.168.1.1
nas                     IN   A   192.168.1.10
pve                    IN   A   192.168.1.20
media-server           IN   A   192.168.1.30
